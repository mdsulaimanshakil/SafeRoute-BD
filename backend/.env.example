# ─────────────────────────────────────────────
#  SafeRoute BD — Environment Configuration
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Oracle Database Connection
DB_USER=your_oracle_username
DB_PASSWORD=your_oracle_password
DB_CONNECTION_STRING=localhost:1522/XEPDB1
# Examples:
#   localhost:1522/XEPDB1      (current SafeRoute BD setup)
#   localhost:1521/XEPDB1      (Oracle XE 21c)
#   localhost:1521/orcl        (Oracle 19c standard)
#   192.168.1.10:1521/ORCLPDB1 (remote)

# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=change_this_to_a_very_long_random_secret_string_at_least_64_chars
JWT_EXPIRES_IN=1d

# Frontend URL (for CORS)
FRONTEND_URL=http://127.0.0.1:5500
